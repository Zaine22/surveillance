        "/api/caseFeedback": {
            "post": {
                "tags": [
                    "Case Management"
                ],
                "summary": "Submit case feedback",
                "operationId": "11bf98c06d23bbd76535387770cf8029",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "case_id",
                                    "url",
                                    "is_illegal"
                                ],
                                "properties": {
                                    "case_id": {
                                        "type": "string",
                                        "example": "CASE123"
                                    },
                                    "url": {
                                        "type": "string",
                                        "format": "url",
                                        "example": "https://example.com"
                                    },
                                    "is_illegal": {
                                        "type": "boolean",
                                        "example": true
                                    },
                                    "legal_basis": {
                                        "type": "string",
                                        "example": "Copyright Act"
                                    },
                                    "reason": {
                                        "type": "string",
                                        "example": "Unauthorised distribution"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "已接收"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "500": {
                        "description": "Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "error"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "反馈保存失败"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "apikey": []
                    }
                ]
            }
        },
